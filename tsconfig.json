{
  "compilerOptions": {
    "sourceMap": true,
    "skipLibCheck": true,
    "inlineSources": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "moduleResolution": "node",
    "baseUrl": "./src",
    "paths": {
      "*": ["*"]
    },
    "target": "ES2020",
    "module": "ESNext",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]
}
