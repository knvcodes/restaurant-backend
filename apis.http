### Variables
@baseUrl = http://localhost:3000
@contentType = application/json


# health check
GET {{baseUrl}}


# AUTH

### register owner
POST {{baseUrl}}/api/auth/register
Content-Type: {{contentType}}

{
  "name": "james",
  "email": "test@yopmail.com",
  "password": "Test@123",
  "role": "owner"
}

### login
POST {{baseUrl}}/api/auth/login
Content-Type: {{contentType}}

{
  "email": "john.smith@restaurant.com",
  "password": "Owner@123"
}

### forgot password
POST {{baseUrl}}/api/auth/forgotPassword
Content-Type: {{contentType}}

{
  "email": "john.smith@restaurant.com"
}

### reset password
POST {{baseUrl}}/api/auth/resetPassword
Content-Type: {{contentType}}

{ 
  "token": "7d6bcbb355fc05faebe5dbe4441ebee882911733c345dc451e9afca48f9abf1a",
  "newPassword": "Owner@1234",
  "confirmPassword": "Owner@1234"
}


